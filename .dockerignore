# VCS / tooling
.git
.gitignore
.claude
.idea
.devcontainer

# Python
venv
**/__pycache__
*.py[cod]
*.log

# Node / frontend (rebuilt inside the image)
**/node_modules
frontend/dist

# Dev-only frontend env (prod build must use .env.production only, not localhost values)
frontend/.env
frontend/.env.local

# Generated at build time (don't ship stale copies into the context)
statfiles/static/vue
staticroot
templates/vue/index.html

# Local runtime data
media
faiss_index.index

# Secrets / local settings (never bake into the image)
.env
config/settings/development.py
config/settings/production.py
